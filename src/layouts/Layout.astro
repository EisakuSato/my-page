---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Eisaku Sato',
	description = '自己紹介・ポートフォリオ・技術ブログ',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<header>
			<nav>
				<a href={import.meta.env.BASE_URL} class="brand">Eisaku Sato</a>
				<div class="links">
					<a href={import.meta.env.BASE_URL}>Home</a>
					<a href={`${import.meta.env.BASE_URL}blog/`}>Blog</a>
				</div>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<p>&copy; {new Date().getFullYear()} Eisaku Sato</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light dark;
		--fg: #1a1a1a;
		--bg: #ffffff;
		--muted: #666;
		--accent: #3b5bdb;
		--border: #e5e5e5;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--fg: #f0f0f0;
			--bg: #101114;
			--muted: #a0a0a0;
			--accent: #8ba3ff;
			--border: #2a2a2e;
		}
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
	}

	body {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		color: var(--fg);
		background: var(--bg);
		line-height: 1.6;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}

	main {
		flex: 1;
		width: 100%;
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem 1.25rem;
	}

	a {
		color: var(--accent);
	}

	header {
		border-bottom: 1px solid var(--border);
	}

	nav {
		max-width: 720px;
		margin: 0 auto;
		padding: 1rem 1.25rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	nav .brand {
		font-weight: 700;
		text-decoration: none;
		color: var(--fg);
	}

	nav .links a {
		margin-left: 1.25rem;
		text-decoration: none;
		color: var(--fg);
	}

	nav .links a:hover {
		color: var(--accent);
	}

	footer {
		border-top: 1px solid var(--border);
		text-align: center;
		padding: 1.5rem;
		color: var(--muted);
		font-size: 0.875rem;
	}
</style>
