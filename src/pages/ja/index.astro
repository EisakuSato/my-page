---
import Layout from '../../layouts/Layout.astro';

const projects = [
	{
		name: 'Project Name',
		description: 'プロジェクトの説明をここに書きます。',
		url: 'https://github.com/EisakuSato',
	},
];

const skills = ['TypeScript', 'React', 'Astro', 'Node.js'];
---

<Layout title="Eisaku Sato" description="自己紹介・ポートフォリオ・技術ブログ" lang="ja">
	<p class="lang-switch"><a href={import.meta.env.BASE_URL}>English</a></p>

	<section>
		<h1>Eisaku Sato</h1>
		<p>自己紹介文をここに書きます。</p>
	</section>

	<section>
		<h2>Skills</h2>
		<ul class="tags">
			{skills.map((skill) => <li>{skill}</li>)}
		</ul>
	</section>

	<section>
		<h2>Projects</h2>
		<ul class="projects">
			{
				projects.map((project) => (
					<li>
						<a href={project.url} target="_blank" rel="noopener noreferrer">
							{project.name}
						</a>
						<p>{project.description}</p>
					</li>
				))
			}
		</ul>
	</section>
</Layout>

<style>
	.lang-switch {
		text-align: right;
		margin: 0 0 1.5rem;
		font-size: 0.875rem;
	}

	section {
		margin-bottom: 2.5rem;
	}

	h1 {
		margin-bottom: 0.25rem;
	}

	.tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		padding: 0;
	}

	.tags li {
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.25rem 0.75rem;
		font-size: 0.875rem;
	}

	.projects {
		list-style: none;
		padding: 0;
	}

	.projects li {
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 1rem;
		margin-bottom: 1rem;
	}

	.projects a {
		font-weight: 600;
		text-decoration: none;
	}

	.projects p {
		margin: 0.25rem 0 0;
		color: var(--muted);
	}
</style>
